import React, { useState } from 'react';
import { CartItem } from '../types';
import { X, Trash2, Plus, Minus, Ticket, Calendar, MapPin, Printer, ArrowRight, ShieldCheck, ShoppingCart } from 'lucide-react';
import { motion, AnimatePresence } from 'motion/react';

interface CartSidebarProps {
  isOpen: boolean;
  onClose: () => void;
  cart: CartItem[];
  onUpdateQty: (itemId: string, newQty: number) => void;
  onRemoveItem: (itemId: string) => void;
  onClearCart: () => void;
}

export default function CartSidebar({
  isOpen,
  onClose,
  cart,
  onUpdateQty,
  onRemoveItem,
  onClearCart
}: CartSidebarProps) {
  // Checkout & UI states
  const [promoCode, setPromoCode] = useState('');
  const [discountPercent, setDiscountPercent] = useState(0);
  const [promoApplied, setPromoApplied] = useState(false);
  const [promoError, setPromoError] = useState('');
  
  const [deliveryDate, setDeliveryDate] = useState('2026-05-26');
  const [address, setAddress] = useState('');
  const [recipientName, setRecipientName] = useState('');

  const [checkoutStep, setCheckoutStep] = useState<'cart' | 'address' | 'receipt'>('cart');
  const [isProcessing, setIsProcessing] = useState(false);
  const [completedOderId, setCompletedOrderId] = useState('');

  // Math totals
  const subtotal = cart.reduce((acc, curr) => acc + (curr.price * curr.quantity), 0);
  const discountAmount = subtotal * (discountPercent / 100);
  const shippingFee = subtotal > 40 ? 0 : 8.50; // free delivery over $40
  const grandTotal = subtotal > 0 ? (subtotal - discountAmount + shippingFee) : 0;

  // Apply discount logic
  const handleApplyPromo = () => {
    setPromoError('');
    if (promoCode.toUpperCase() === 'FRESH25') {
      setDiscountPercent(25);
      setPromoApplied(true);
    } else if (promoCode.toUpperCase() === 'ORCHARD10') {
      setDiscountPercent(10);
      setPromoApplied(true);
    } else {
      setPromoError('Invalid code. Try FRESH25 or ORCHARD10.');
    }
  };

  // Submit checkout order
  const handleSecureCheckout = (e: React.FormEvent) => {
    e.preventDefault();
    if (!address || !recipientName) {
      alert("Fill in the beautiful recipient and delivery coordinates to guarantee safe botanical hydration.");
      return;
    }

    setIsProcessing(true);

    // Simulate packing steps for maximum high-touch feel
    setTimeout(() => {
      setIsProcessing(false);
      setCompletedOrderId(`SR-2026-${Math.floor(100000 + Math.random() * 900000)}`);
      setCheckoutStep('receipt');
    }, 2200);
  };

  // Reset and clean
  const handleStartFresh = () => {
    onClearCart();
    setPromoCode('');
    setDiscountPercent(0);
    setPromoApplied(false);
    setAddress('');
    setRecipientName('');
    setCheckoutStep('cart');
  };

  if (!isOpen) return null;

  return (
    <AnimatePresence>
      <div 
        id="cart-overlay-shadow"
        onClick={onClose}
        className="fixed inset-0 z-50 bg-stone-950/45 backdrop-blur-xs flex justify-end"
      >
        <motion.div
          initial={{ x: '100%' }}
          animate={{ x: 0 }}
          exit={{ x: '100%' }}
          transition={{ type: 'tween', duration: 0.35 }}
          onClick={(e) => e.stopPropagation()}
          id="cart-drawer-body"
          className="w-full max-w-md bg-white dark:bg-stone-900 h-screen shadow-2xl flex flex-col justify-between overflow-hidden"
        >
          {/* HEADER BAR */}
          <div className="p-5 border-b border-stone-200/80 dark:border-stone-800/80 flex justify-between items-center bg-stone-50 dark:bg-stone-950">
            <div className="flex items-center gap-2">
              <ShoppingCart size={18} className="text-emerald-800 dark:text-emerald-400" />
              <h3 className="font-serif text-lg font-black text-stone-900 dark:text-white">
                {checkoutStep === 'receipt' ? 'Crate Registered' : 'Your Organic Crate'}
              </h3>
              <span className="text-[10px] font-mono bg-stone-200/60 dark:bg-stone-800 px-2 py-0.5 rounded-full text-stone-700 dark:text-stone-300 font-bold">
                {cart.length} items
              </span>
            </div>
            <button
              id="close-cart-drawer-btn"
              onClick={onClose}
              className="p-1.5 transition-colors duration-150 text-stone-400 dark:text-stone-500 hover:text-stone-700 dark:hover:text-stone-200 hover:bg-stone-100 dark:hover:bg-stone-800/80 rounded-lg border border-stone-200/50 dark:border-stone-800"
            >
              <X size={15} />
            </button>
          </div>

          {/* CHECKOUT STEP BODY */}
          <div className="flex-1 overflow-y-auto p-5">
            
            {/* STEP 1: CART LISTING */}
            {checkoutStep === 'cart' && (
              <div className="space-y-5">
                {cart.length === 0 ? (
                  <div className="text-center py-20">
                    <span className="text-5xl select-none" role="img" aria-label="cart info">🍎</span>
                    <h4 className="text-sm font-serif font-bold text-stone-700 dark:text-stone-300 mt-4">Crate is perfectly empty</h4>
                    <p className="text-xs text-stone-400 dark:text-stone-500 max-w-[240px] mx-auto mt-1 leading-normal">
                      Add freshly hand-polished fruits or assemble a bespoke gift crate box to initiate selection.
                    </p>
                  </div>
                ) : (
                  <>
                    <div className="space-y-3.5">
                      {cart.map((item) => (
                        <div 
                          key={item.id} 
                          className="flex items-start gap-3 bg-stone-50/50 dark:bg-stone-950/20 p-3.5 rounded-xl border border-stone-100 dark:border-stone-850"
                        >
                          <span className="text-3xl select-none" role="img" aria-label={item.name}>
                            {item.image}
                          </span>
                          
                          <div className="flex-1 min-w-0">
                            <span className="block text-xs font-mono text-stone-400 dark:text-stone-500 uppercase tracking-widest leading-none mb-0.5">
                              {item.type.replace('_', ' ')}
                            </span>
                            <span className="block font-serif text-sm font-black text-stone-800 dark:text-stone-200 leading-tight">
                              {item.name}
                            </span>
                            
                            {/* Rendering custom box ingredients */}
                            {item.customDetails && (
                              <div className="mt-1.5 bg-amber-500/5 dark:bg-amber-900/10 border border-amber-500/10 dark:border-amber-900/30 p-2 rounded-lg text-[10px] space-y-1 text-amber-900 dark:text-amber-400 font-mono">
                                <span className="font-bold underline block">Specs: Wrapper - {item.customDetails.crateStyle.replace('_', ' ')}</span>
                                <div className="flex flex-wrap gap-x-2 gap-y-0.5">
                                  {item.customDetails.components.map((comp, idx) => (
                                    <span key={idx}>• {comp.fruitName} (x{comp.qty})</span>
                                  ))}
                                </div>
                                <span className="block text-[8px] italic text-stone-500 dark:text-stone-500 max-w-full truncate border-t border-dashed border-stone-200 dark:border-stone-800 pt-1">
                                  Note: "{item.customDetails.cardText}"
                                </span>
                              </div>
                            )}

                            <div className="flex justify-between items-center mt-2.5">
                              {/* Price summary */}
                              <span className="text-xs font-mono font-semibold text-emerald-800 dark:text-emerald-400">
                                ${item.price.toFixed(2)}
                              </span>

                              {/* Quantity selectors */}
                              <div className="flex items-center gap-1.5 bg-white dark:bg-stone-800 border border-stone-200 dark:border-stone-750 rounded-lg p-0.5">
                                <button
                                  onClick={() => onUpdateQty(item.id, item.quantity - 1)}
                                  className="h-5 w-5 rounded-md hover:bg-stone-50 dark:hover:bg-stone-750 flex items-center justify-center text-stone-500 dark:text-stone-400 hover:text-stone-800 dark:hover:text-stone-200 text-xs"
                                >
                                  <Minus size={11} />
                                </button>
                                <span className="text-xs font-mono font-bold w-5 text-center text-stone-700 dark:text-stone-300">
                                  {item.quantity}
                                </span>
                                <button
                                  onClick={() => onUpdateQty(item.id, item.quantity + 1)}
                                  className="h-5 w-5 rounded-md hover:bg-stone-50 dark:hover:bg-stone-750 flex items-center justify-center text-stone-500 dark:text-stone-400 hover:text-stone-800 dark:hover:text-stone-200 text-xs"
                                >
                                  <Plus size={11} />
                                </button>
                              </div>
                            </div>
                          </div>

                          {/* Quick delete */}
                          <button
                            onClick={() => onRemoveItem(item.id)}
                            className="p-1 text-stone-300 dark:text-stone-650 hover:text-red-700 hover:bg-red-50 dark:hover:bg-red-900/20 border border-transparent hover:border-red-100 rounded-md mt-1 transition-colors"
                            title="Remove specimen"
                          >
                            <Trash2 size={13} />
                          </button>

                        </div>
                      ))}
                    </div>

                    {/* PROMO CODE BLOCK */}
                    <div className="bg-stone-50 dark:bg-stone-950/40 border border-stone-200/60 dark:border-stone-800 p-4 rounded-xl space-y-3">
                      <label className="block text-[9px] font-mono text-stone-500 dark:text-stone-400 uppercase tracking-widest leading-none">
                        APPLY COUPON DEDUCTION
                      </label>
                      
                      <div className="flex gap-2">
                        <input
                          id="coupon-input"
                          type="text"
                          value={promoCode}
                          onChange={(e) => setPromoCode(e.target.value)}
                          placeholder="FRESH25 (25% off)"
                          disabled={promoApplied}
                          className="flex-1 bg-white dark:bg-stone-900 border border-stone-200 dark:border-stone-800 text-stone-800 dark:text-stone-100 text-xs rounded-lg px-3 py-1.5 focus:border-stone-400 focus:ring-0 uppercase font-mono tracking-wider disabled:bg-stone-100/50 dark:disabled:bg-stone-850/50"
                        />
                        <button
                          id="apply-coupon-btn"
                          onClick={handleApplyPromo}
                          disabled={promoApplied}
                          className="px-4 py-1.5 bg-stone-900 dark:bg-stone-100 dark:text-stone-950 hover:bg-stone-950 dark:hover:bg-white text-white font-mono text-xs font-semibold rounded-lg leading-none disabled:bg-stone-300 dynamic-colors"
                        >
                          {promoApplied ? 'Saved' : 'Apply'}
                        </button>
                      </div>

                      {promoApplied && (
                        <p className="text-[10px] font-mono text-emerald-700 dark:text-emerald-400 font-bold flex items-center gap-1 leading-none">
                          ✓ Promo code successfully computed! {discountPercent}% deducted from purchase subtotal.
                        </p>
                      )}
                      
                      {promoError && (
                        <p className="text-[10px] font-mono text-rose-700 dark:text-rose-400 font-medium">
                          ⚠ {promoError}
                        </p>
                      )}
                    </div>
                  </>
                )}
              </div>
            )}

            {/* STEP 2: ADDRESS COORDS */}
            {checkoutStep === 'address' && (
              <form onSubmit={handleSecureCheckout} className="space-y-5">
                <div className="flex items-center gap-1 text-xs font-mono text-stone-500 dark:text-stone-400 uppercase tracking-widest mb-2 border-b border-stone-100 dark:border-stone-800 pb-2">
                  <MapPin size={13} className="text-emerald-700 dark:text-emerald-400" />
                  COURIER DISPATCH COORDINATES
                </div>

                {/* Recipient */}
                <div>
                  <label className="block text-[10px] font-mono text-stone-500 dark:text-stone-400 uppercase tracking-wider mb-2">
                    RECIPIENT NAME
                  </label>
                  <input
                    id="recipient-name-input"
                    type="text"
                    required
                    value={recipientName}
                    onChange={(e) => setRecipientName(e.target.value)}
                    placeholder="e.g. Lillian Vance"
                    className="w-full bg-stone-50 dark:bg-stone-950 border border-stone-200 dark:border-stone-800 text-xs rounded-xl px-3 py-2.5 focus:border-stone-400 focus:ring-0 font-medium text-stone-800 dark:text-stone-100 placeholder-stone-400 dark:placeholder-stone-600"
                  />
                </div>

                {/* Shipping Coordinates */}
                <div>
                  <label className="block text-[10px] font-mono text-stone-500 dark:text-stone-400 uppercase tracking-wider mb-2">
                    DESTINATION SHIPPING ADDRESS
                  </label>
                  <input
                    id="recipient-addr-input"
                    type="text"
                    required
                    value={address}
                    onChange={(e) => setAddress(e.target.value)}
                    placeholder="e.g. 104 Willow Glen Lane, Seattle WA, 98101"
                    className="w-full bg-stone-50 dark:bg-stone-950 border border-stone-200 dark:border-stone-800 text-xs rounded-xl px-3 py-2.5 focus:border-stone-400 focus:ring-0 font-medium text-stone-800 dark:text-stone-100 placeholder-stone-400 dark:placeholder-stone-600"
                  />
                </div>

                {/* Delivery Date selection starting tomorrow */}
                <div>
                  <label className="block text-[10px] font-mono text-stone-500 dark:text-stone-400 uppercase tracking-wider mb-2 flex items-center gap-1.5">
                    <Calendar size={13} className="text-stone-400 dark:text-stone-500" />
                    SELECT HYDRATION GUARANTEED TRANSIT DATE
                  </label>
                  <div className="grid grid-cols-2 gap-2">
                    {[
                      { val: '2026-05-26', dateStr: 'TOMORROW', sub: 'May 26, 2026' },
                      { val: '2026-05-27', dateStr: 'WEDNESDAY', sub: 'May 27, 2026' },
                      { val: '2026-05-28', dateStr: 'THURSDAY', sub: 'May 28, 2026' },
                      { val: '2026-05-29', dateStr: 'FRIDAY', sub: 'May 29, 2026' }
                    ].map((d) => (
                      <button
                        key={d.val}
                        type="button"
                        onClick={() => setDeliveryDate(d.val)}
                        className={`p-2.5 rounded-xl border text-left transition-all ${
                          deliveryDate === d.val
                            ? 'border-emerald-800 dark:border-emerald-600 bg-emerald-50/50 dark:bg-emerald-950/20 shadow-xs ring-1 ring-emerald-800/10'
                            : 'border-stone-200 dark:border-stone-800 hover:border-stone-300 dark:hover:border-stone-700 bg-white dark:bg-stone-900 text-stone-800 dark:text-stone-300'
                        }`}
                      >
                        <span className="block text-[9px] font-mono font-bold text-emerald-800 dark:text-emerald-400">{d.dateStr}</span>
                        <span className="block text-xs font-bold text-stone-700 dark:text-stone-300">{d.sub}</span>
                      </button>
                    ))}
                  </div>
                </div>

                {/* Security shield badge */}
                <div className="bg-emerald-500/5 dark:bg-emerald-900/5 border border-emerald-500/15 dark:border-emerald-900/30 p-4 rounded-xl flex gap-3 items-start mt-8">
                  <ShieldCheck size={18} className="text-emerald-700 dark:text-emerald-400 shrink-0 mt-0.5 animate-pulse" />
                  <div className="text-[10px] font-mono text-emerald-800 dark:text-emerald-300 leading-normal">
                    <strong>CLIMATIC STABILITY GUARANTEED</strong>
                    <p className="text-emerald-900/60 dark:text-emerald-400/60 mt-0.5">
                      Specimens packed inside structural honeycomb insulation modules surrounded of non-toxic cooling gel. Under 18°C temperature maintained up to 48h.
                    </p>
                  </div>
                </div>

                {/* SUBMIT BUTTON */}
                <button
                  id="final-pay-submit"
                  type="submit"
                  disabled={isProcessing}
                  className="w-full h-11 bg-emerald-800 hover:bg-emerald-900 text-white text-xs font-sans font-bold uppercase tracking-wider rounded-xl transition-all flex items-center justify-center gap-2 mt-2 shadow-sm"
                >
                  {isProcessing ? (
                    <>
                      <span className="animate-spin h-3.5 w-3.5 border-2 border-white border-t-transparent rounded-full" />
                      <span>Wrapping specimens in silk...</span>
                    </>
                  ) : (
                    <>
                      <span>Submit Secure Reservation Booking</span>
                      <ArrowRight size={13} />
                    </>
                  )}
                </button>
              </form>
            )}

            {/* STEP 3: HIGH END INVOICE THERMAL RECEIPT VECTOR */}
            {checkoutStep === 'receipt' && (
              <div className="space-y-6">
                
                {/* Visual success notice */}
                <div className="text-center pb-2">
                  <span className="text-4xl animate-bounce">🎇</span>
                  <h4 className="text-lg font-serif font-black text-stone-900 dark:text-white mt-2">SPECIMENS REGISTERED</h4>
                  <p className="text-xs text-stone-500 dark:text-stone-400 max-w-[280px] mx-auto mt-1">
                    Your organic crate box is sealed and booked on temperature-controlled transit.
                  </p>
                </div>

                {/* The thermal receipt vector */}
                <div id="thermal-receipt-invoice" className="bg-stone-50 dark:bg-stone-950/40 border border-stone-200/80 dark:border-stone-800 p-5 rounded-2xl shadow-inner font-mono relative overflow-hidden">
                  {/* Jagged paper trim visual styling at top & bottom */}
                  <div className="absolute top-0 right-0 left-0 h-1 bg-dashed bg-[size:10px_10px] text-white" />
                  
                  {/* Crate info */}
                  <div className="text-center pt-2 pb-4 border-b border-stone-300 dark:border-stone-800">
                    <span className="text-xs font-bold block select-none text-stone-900 dark:text-stone-100">SUNRIPE ORCHARDS INC</span>
                    <span className="text-[8px] text-stone-400 dark:text-stone-500 block uppercase">198 FRESH BOTANICS BLVD, SEATTLE</span>
                    <span className="text-[9px] text-stone-600 dark:text-stone-400 block mt-1">INVOICE: #{completedOderId}</span>
                    <span className="text-[8px] text-stone-500 dark:text-stone-500 block">TIME: 2026-05-25 14:02 UTC</span>
                  </div>

                  {/* Address coordinates */}
                  <div className="text-[9px] py-3.5 border-b border-stone-300 dark:border-stone-800 space-y-1">
                    <div>
                      <span className="text-stone-400">RECIPIENT: </span>
                      <span className="text-stone-800 dark:text-stone-200 font-bold uppercase">{recipientName}</span>
                    </div>
                    <div>
                      <span className="text-stone-400">COORDS: </span>
                      <span className="text-stone-800 dark:text-stone-350 text-[8px] leading-tight block">{address}</span>
                    </div>
                    <div>
                      <span className="text-stone-400">TRANSIT: </span>
                      <span className="text-emerald-700 dark:text-emerald-400 font-bold">{deliveryDate}</span>
                    </div>
                  </div>

                  {/* Items catalog */}
                  <div className="py-3.5 text-[9px] border-b border-stone-300 dark:border-stone-800 space-y-2">
                    <div className="flex justify-between font-bold text-stone-400 pb-1">
                      <span>QTY / ITEM DESCRIPTION</span>
                      <span>PRICE</span>
                    </div>
                    {cart.map((item) => (
                      <div key={item.id} className="flex justify-between text-[9px] text-stone-800 dark:text-stone-300 leading-tight">
                        <span className="truncate max-w-[230px]">
                          x{item.quantity} {item.name}
                        </span>
                        <span>${(item.price * item.quantity).toFixed(2)}</span>
                      </div>
                    ))}
                  </div>

                  {/* Summary math sheet */}
                  <div className="py-3.5 text-[10px] space-y-1.5 border-b border-dashed border-stone-300 dark:border-stone-800">
                    <div className="flex justify-between">
                      <span className="text-stone-500">SPECIMENS SUBTOTAL:</span>
                      <span className="text-stone-800 dark:text-stone-300">${subtotal.toFixed(2)}</span>
                    </div>
                    {discountAmount > 0 && (
                      <div className="flex justify-between text-emerald-700 dark:text-emerald-400 font-semibold">
                        <span>COUPON DEDUCTION ({discountPercent}%):</span>
                        <span>-${discountAmount.toFixed(2)}</span>
                      </div>
                    )}
                    <div className="flex justify-between">
                      <span className="text-stone-500">THERMAL COLD TRANSIT:</span>
                      <span className="text-stone-800 dark:text-stone-300">
                        {shippingFee === 0 ? 'FREE OVER $40' : `$${shippingFee.toFixed(2)}`}
                      </span>
                    </div>
                    <div className="flex justify-between text-xs font-bold text-stone-900 dark:text-white border-t border-stone-200 dark:border-stone-800 pt-1.5">
                      <span>TOTAL PAID (SECURE):</span>
                      <span>${grandTotal.toFixed(2)}</span>
                    </div>
                  </div>

                  {/* Footer declaration */}
                  <div className="text-center pt-4 text-[8px] text-stone-400 dark:text-stone-500">
                    <span className="block italic">"A healthy body is a temple of light."</span>
                    <span className="block font-bold tracking-widest uppercase mt-1">Thank you for supporting organic soils</span>
                  </div>
                </div>

                {/* Action buttons */}
                <div className="grid grid-cols-2 gap-3 pt-2">
                  <button
                    onClick={() => {
                      alert("Sending invoice ticket to temperature-control print spooler...");
                    }}
                    className="py-2.5 border border-stone-200 dark:border-stone-800 hover:border-stone-400 dark:hover:border-stone-600 text-stone-600 dark:text-stone-200 font-mono text-[11px] font-bold rounded-xl flex items-center justify-center gap-1.5"
                  >
                    <Printer size={13} />
                    Print Receipt
                  </button>
                  <button
                    onClick={handleStartFresh}
                    className="py-2.5 bg-stone-900 dark:bg-stone-100 hover:bg-stone-950 dark:hover:bg-white text-white dark:text-stone-950 font-mono text-[11px] font-bold rounded-xl flex items-center justify-center"
                  >
                    Start New Order
                  </button>
                </div>

              </div>
            )}

          </div>

          {/* MASTER BILLING CALCULATION ACCORDION FOOTER (Sticky) */}
          {checkoutStep !== 'receipt' && cart.length > 0 && (
            <div className="bg-stone-100 dark:bg-stone-950 p-5 border-t border-stone-200/80 dark:border-stone-800 space-y-4 shadow-[0_-5px_15px_-5px_rgba(0,0,0,0.05)]">
              
              <div className="space-y-1.5 text-xs font-mono">
                <div className="flex justify-between text-stone-500 dark:text-stone-400">
                  <span>Botanical Subtotal:</span>
                  <span className="text-stone-700 dark:text-stone-300">${subtotal.toFixed(2)}</span>
                </div>
                {discountAmount > 0 && (
                  <div className="flex justify-between text-emerald-700 dark:text-emerald-450 font-bold">
                    <span>Coupon Save ({discountPercent}%):</span>
                    <span>-${discountAmount.toFixed(2)}</span>
                  </div>
                )}
                <div className="flex justify-between text-stone-500 dark:text-stone-400">
                  <span>Aura Thermal Transit:</span>
                  <span className="text-stone-700 dark:text-stone-300">
                    {shippingFee === 0 ? 'FREE OVER $40' : `$${shippingFee.toFixed(2)}`}
                  </span>
                </div>
                
                <div className="flex justify-between font-bold text-sm text-stone-900 dark:text-white border-t border-dashed border-stone-300 dark:border-stone-800 pt-2">
                  <span>Grand Total:</span>
                  <span>${grandTotal.toFixed(2)}</span>
                </div>
              </div>

              {/* ACTION BTNS */}
              {checkoutStep === 'cart' ? (
                <button
                  id="checkout-proceed-btn"
                  onClick={() => setCheckoutStep('address')}
                  disabled={cart.length === 0}
                  className="w-full h-11 bg-emerald-800 hover:bg-emerald-950 dark:bg-emerald-700 dark:hover:bg-emerald-600 text-white text-xs font-sans font-bold uppercase tracking-wider rounded-xl transition-all flex items-center justify-center gap-2 shadow-sm"
                >
                  <span>Select Destination Coordinates</span>
                  <ArrowRight size={13} />
                </button>
              ) : (
                <button
                  id="back-to-cart-btn"
                  onClick={() => setCheckoutStep('cart')}
                  className="w-full h-10 border border-stone-200 dark:border-stone-800 hover:border-stone-400 dark:hover:border-stone-700 text-stone-700 dark:text-stone-300 text-xs font-mono font-semibold rounded-xl transition-colors bg-white dark:bg-stone-900 flex items-center justify-center"
                >
                  ← Modify Items Sheet
                </button>
              )}
            </div>
          )}

        </motion.div>
      </div>
    </AnimatePresence>
  );
}
